generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Availability {
  id            String        @id
  mentorId      String
  dayOfWeek     Int
  startTime     String
  endTime       String
  MentorProfile MentorProfile @relation(fields: [mentorId], references: [id])
}

model ForumAnswer {
  id            String        @id
  questionId    String
  authorId      String
  content       String
  upvotes       Int           @default(0)
  isMentor      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  ForumQuestion ForumQuestion @relation(fields: [questionId], references: [id])
}

model ForumQuestion {
  id          String        @id
  authorId    String
  title       String
  body        String
  tags        String[]
  university  String?
  upvotes     Int           @default(0)
  createdAt   DateTime      @default(now())
  ForumAnswer ForumAnswer[]
}

model MentorProfile {
  id             String         @id
  userId         String         @unique
  university     String
  universitySlug String
  course         String
  yearOfStudy    Int
  bio            String?
  uniEmail       String?
  isVerified     Boolean        @default(false)
  expertiseTags  String[]
  languages      String[]
  rating         Float          @default(0)
  totalSessions  Int            @default(0)
  earnings       Float          @default(0)
  Availability   Availability[]
  User           User           @relation(fields: [userId], references: [id])
  SessionType    SessionType[]
}

model Message {
  id         String   @id
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [senderId], references: [id])
}

model Review {
  id            String   @id
  sessionId     String   @unique
  seekerId      String
  mentorId      String
  rating        Float
  helpfulness   Int
  communication Int
  knowledge     Int
  friendliness  Int
  comment       String?
  recommend     Boolean
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [seekerId], references: [id])
  Session       Session  @relation(fields: [sessionId], references: [id])
}

model SeekerProfile {
  id               String   @id
  userId           String   @unique
  targetUniversity String?
  targetCountry    String?
  savedMentors     String[]
  User             User     @relation(fields: [userId], references: [id])
}

model Session {
  id            String        @id
  mentorId      String
  seekerId      String
  sessionTypeId String
  scheduledAt   DateTime
  status        SessionStatus @default(PENDING)
  topic         String
  roomUrl       String?
  notes         String?
  createdAt     DateTime      @default(now())
  Review        Review?
  User          User          @relation(fields: [seekerId], references: [id])
  SessionType   SessionType   @relation(fields: [sessionTypeId], references: [id])
}

model SessionType {
  id            String        @id
  mentorId      String
  label         String
  durationMins  Int
  price         Float
  Session       Session[]
  MentorProfile MentorProfile @relation(fields: [mentorId], references: [id])
}

model User {
  id            String         @id
  name          String
  email         String         @unique
  password      String?
  role          Role           @default(SEEKER)
  profilePhoto  String?
  country       String?
  createdAt     DateTime       @default(now())
  MentorProfile MentorProfile?
  Message       Message[]
  Review        Review[]
  SeekerProfile SeekerProfile?
  Session       Session[]
}

enum Role {
  SEEKER
  MENTOR
  ADMIN
}

enum SessionStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}
